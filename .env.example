# StockNet Environment Variables
# Copy this to .env and adjust values for your local environment

# ─── Port Configuration ──────────────────────────────────────
BACKEND_PORT=8000
POSTGRES_PORT=5432

# ─── Database ────────────────────────────────────────────────
POSTGRES_DB=stocknetdb
POSTGRES_USER=stocknet
POSTGRES_PASSWORD=stocknet123

# ─── Backend ─────────────────────────────────────────────────
# Note: For internal Docker communication, DATABASE_URL points to the service name 'postgres'.
DATABASE_URL=postgresql://stocknet:stocknet123@postgres:5432/stocknetdb
SECRET_KEY=stocknet-super-secret-key-change-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Price Simulation ─────────────────────────────────────────
UPDATE_INTERVAL_SECONDS=30
